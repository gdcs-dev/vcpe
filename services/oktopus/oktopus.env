# Oktopus standalone environment configuration.
# This file is rendered into /etc/oktopus/oktopus.env at deploy time by vcpe.
# Defaults below are suitable for a local dev deployment; override via
# the manifest config block or by mounting a custom file at runtime.

# NATS — internal broker; credentials must match nats.cfg
NATS_URL=nats://oktopususer:oktopuspw@localhost:4222
NATS_USER=oktopususer
NATS_PW=oktopuspw
NATS_ENABLE_TLS=false

# WebSocket MTP
WS_ADDR=localhost

# STOMP MTP
STOMP_USERNAME=
STOMP_PASSWORD=
STOMP_SERVER=localhost:61613
STOMP_USER=
STOMP_PASSWD=

# MQTT MTP
MQTT_PORT=:1883
MQTT_TLS_PORT=:8883
MQTT_NO_TLS=true
MQTT_TLS=false
REDIS_ENABLE=false
AUTH_ENABLE=false
MQTT_URL=tcp://localhost:1883
MQTT_CLIENT_ID=mqtt-adapter
MQTT_USERNAME=oktopusController

# MongoDB
MONGO_URI=mongodb://localhost:27017

# TaaS (USP conformance test runner)
TAAS_PORT=8001
SECRET_API_KEY=supersecretkey
TAAS_CORS=*

# Default admin account seeded on first boot.
# Change ADMIN_PASSWORD before exposing this container on a shared network.
ADMIN_EMAIL=admin@vcpe.local
ADMIN_NAME=Admin
ADMIN_PASSWORD=changeme
