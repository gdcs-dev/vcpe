#!/bin/bash
set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
source "$SCRIPT_DIR/../../../platform/scripts/lib/common.sh"
source "$SCRIPT_DIR/lib/render.sh"
source "$SCRIPT_DIR/lib/podman.sh"

usage() {
    cat <<'EOF'
Usage: services/bng/scripts/bng <build|push|render|up|down|status|logs> [customer-id]
EOF
}

cmd=${1:-}
customer_id=${2:-}

case "$cmd" in
    build)
        build_image
        ;;
    push)
        push_image
        ;;
    render)
        require_customer_id "$customer_id"
        render_customer "$customer_id"
        ;;
    up)
        require_customer_id "$customer_id"
        render_customer "$customer_id"
        compose_up "$customer_id"
        ;;
    down)
        require_customer_id "$customer_id"
        compose_down "$customer_id"
        ;;
    status)
        require_customer_id "$customer_id"
        container_status "$customer_id"
        ;;
    logs)
        require_customer_id "$customer_id"
        container_logs "$customer_id"
        ;;
    *)
        usage
        exit 1
        ;;
esac