#!/bin/bash
set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
source "$SCRIPT_DIR/../../../platform/scripts/lib/common.sh"
source "$REPO_ROOT/platform/scripts/lib/bridges.sh"

CLIENT_IMAGE=${CLIENT_IMAGE:-docker.io/library/alpine:3.19}

usage() {
    cat <<'EOF'
Usage: services/client/scripts/client <up|down|status|logs|shell> <target>

Target format:
  <peer>-p<1-4>

Examples:
  client up mv1-r21-7-p1
  client shell xb10-7-p2
EOF
}

require_target() {
    [[ -n "${1:-}" ]] || die "target is required"
}

require_customer_id() {
    case "$1" in
        7|9|20)
            ;;
        *)
            die "client supports only customer ids 7, 9, and 20"
            ;;
    esac
}

parse_target() {
    local target=$1

    if [[ ! "$target" =~ ^(.+)-p([1-4])$ ]]; then
        die "target must end in -p1 through -p4"
    fi

    local peer_name=${BASH_REMATCH[1]}
    local port_index=${BASH_REMATCH[2]}

    local customer_id
    case "$peer_name" in
        *-7)
            customer_id=7
            ;;
        *-9)
            customer_id=9
            ;;
        *-20)
            customer_id=20
            ;;
        *)
            die "target must identify a supported customer peer such as mv1-r21-7-p1 or xb10-7-p2"
            ;;
    esac

    require_customer_id "$customer_id"

    printf '%s|lan-p%s|%s\n' "$peer_name" "$port_index" "$customer_id"
}

container_name() {
    local target=$1
    printf 'client-%s\n' "$target"
}

target_network_name() {
    local target=$1
    local peer_name
    local lan_port
    local customer_id
    IFS='|' read -r peer_name lan_port customer_id <<< "$(parse_target "$target")"
    customer_lan_network "$lan_port" "$customer_id"
}

target_peer_name() {
    local target=$1
    local peer_name
    local lan_port
    local customer_id
    IFS='|' read -r peer_name lan_port customer_id <<< "$(parse_target "$target")"
    printf '%s\n' "$peer_name"
}

target_gateway_info() {
    local target=$1
    local peer_name
    local gateway4
    local gateway6

    peer_name=$(target_peer_name "$target")
    podman container exists "$peer_name" || die "missing peer container: $peer_name"

    gateway4=$(podman exec "$peer_name" ip -o -4 addr show dev brlan0 | awk 'NR==1 {print $4}')
    gateway6=$(podman exec "$peer_name" ip -o -6 addr show dev brlan0 scope global | awk 'NR==1 {print $4}')

    [[ -n "$gateway4" ]] || die "peer $peer_name is missing brlan0 IPv4 configuration"
    [[ -n "$gateway6" ]] || die "peer $peer_name is missing brlan0 IPv6 configuration"

    printf '%s|%s\n' "$gateway4" "$gateway6"
}

target_client_addresses() {
    local target=$1
    local gateway4_cidr
    local gateway6_cidr
    local gateway4
    local gateway6
    local gateway4_prefix
    local gateway6_prefix
    local gateway6_mask

    IFS='|' read -r gateway4_cidr gateway6_cidr <<< "$(target_gateway_info "$target")"

    gateway4=${gateway4_cidr%/*}
    gateway6=${gateway6_cidr%/*}
    gateway6_mask=${gateway6_cidr#*/}

    gateway4_prefix=${gateway4%.*}
    gateway6_prefix=${gateway6%::*}

    printf '%s.115/24|%s::da/%s|%s|%s\n' "$gateway4_prefix" "$gateway6_prefix" "$gateway6_mask" "$gateway4" "$gateway6"
}

remove_container_if_exists() {
    local name=$1
    if podman container exists "$name"; then
        podman rm -f "$name" >/dev/null
    fi
}

run_container() {
    local target=$1
    local name
    local client_network_name
    local client_ipv4
    local client_ipv6
    local gateway4
    local gateway6

    name=$(container_name "$target")
    client_network_name=$(target_network_name "$target")
    IFS='|' read -r client_ipv4 client_ipv6 gateway4 gateway6 <<< "$(target_client_addresses "$target")"

    require_cmd podman
    setup_bridges
    podman network exists "$client_network_name" || die "missing podman network: $client_network_name"

    remove_container_if_exists "$name"

    podman run -d \
        --name "$name" \
        --hostname "$name" \
        --network "$client_network_name" \
        --cap-add NET_ADMIN \
        --cap-add NET_RAW \
        "$CLIENT_IMAGE" \
        /bin/sh -lc 'ip addr add "$0" dev eth0 && ip -6 addr add "$1" dev eth0 && ip route replace default via "$2" dev eth0 && ip -6 route replace default via "$3" dev eth0 && trap "exit 0" TERM INT; while :; do sleep 3600; done' \
        "$client_ipv4" "$client_ipv6" "$gateway4" "$gateway6"
}

stop_container() {
    local target=$1
    remove_container_if_exists "$(container_name "$target")"
}

show_status() {
    local target=$1
    podman ps -a --filter "name=$(container_name "$target")"
}

show_logs() {
    local target=$1
    podman logs "$(container_name "$target")"
}

open_shell() {
    local target=$1
    exec podman exec -it "$(container_name "$target")" /bin/sh
}

cmd=${1:-}
target=${2:-}

case "$cmd" in
    up)
        require_target "$target"
        run_container "$target"
        ;;
    down)
        require_target "$target"
        stop_container "$target"
        ;;
    status)
        require_target "$target"
        show_status "$target"
        ;;
    logs)
        require_target "$target"
        show_logs "$target"
        ;;
    shell)
        require_target "$target"
        open_shell "$target"
        ;;
    *)
        usage
        exit 1
        ;;
esac