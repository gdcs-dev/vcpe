#!/bin/bash
set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
source "$SCRIPT_DIR/../../../platform/scripts/lib/common.sh"
source "$REPO_ROOT/platform/scripts/lib/bridges.sh"
source "$SCRIPT_DIR/lib/podman.sh"

usage() {
    cat <<'EOF'
Usage: services/webpa/scripts/webpa <build|push|up|down|status|logs>
EOF
}

cmd=${1:-}

case "$cmd" in
    build)
        build_webpa_image
        ;;
    push)
        push_webpa_image
        ;;
    up)
        setup_bridges
        compose_up_webpa
        setup_bridges
        ;;
    down)
        compose_down_webpa
        ;;
    status)
        container_status_webpa
        ;;
    logs)
        container_logs_webpa
        ;;
    *)
        usage
        exit 1
        ;;
esac
