#!/bin/bash
set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
source "$SCRIPT_DIR/../../../platform/scripts/lib/common.sh"
source "$REPO_ROOT/platform/scripts/lib/bridges.sh"
source "$REPO_ROOT/platform/scripts/lib/firewall.sh"

ROUTERD_IMAGE_NAME=${ROUTERD_IMAGE_NAME:-ghcr.io/gdcs-dev/routerd:dev}
CUSTOMERS_DIR="$ROUTERD_ROOT/customers"
ROUTERD_HOST_CARGO_HOME=${ROUTERD_HOST_CARGO_HOME:-${CARGO_HOME:-$HOME/.cargo}}

usage() {
    cat <<'EOF'
Usage: services/routerd/scripts/routerd <build|fetch|compile|push|up|down|status|logs> [customer-id]

Commands:
  build              build the routerd container image (tooling only; no cargo build)
  fetch              host cargo fetch in ROUTERD_SOURCE_ROOT to populate ~/.cargo (uses
                     the host SSH agent for git deps like proc-monitor-rs)
  compile            run "cargo build --release --offline --bin routerd --bin routerctl"
                     inside the container against the bind-mounted ROUTERD_SOURCE_ROOT
  push               push the image
  up <id>            start routerd for customer <id>
  down <id>          stop routerd for customer <id>
  status <id>        show routerd container status for customer <id>
  logs <id>          tail routerd container logs for customer <id>

Environment:
  ROUTERD_SOURCE_ROOT     path to the routerd Rust workspace (defaults to ../routerd)
  ROUTERD_HOST_CARGO_HOME host cargo home shared with the build container (defaults to ~/.cargo)
EOF
}

require_routerd_customer_id() {
    [[ -n "${1:-}" ]] || die "customer id is required"
    case "$1" in
        7|9|20)
            ;;
        *)
            die "first-pass routerd supports only customer ids 7, 9, and 20"
            ;;
    esac
}

ensure_routerd_runtime_root() {
    mkdir -p "$ROUTERD_RUNTIME_ROOT"
}

compose_project_name() {
    local customer_id=$1
    printf 'podman-routerd-%s\n' "$customer_id"
}

compose_env_file() {
    local customer_id=$1
    local runtime_dir="$ROUTERD_RUNTIME_ROOT/$customer_id"
    local env_file="$runtime_dir/compose.env"
    local customer_file="$CUSTOMERS_DIR/${customer_id}.env"
    local source_root

    [[ -f "$customer_file" ]] || die "missing routerd customer config: $customer_file"
    source_root=$(resolve_routerd_source_root)
    mkdir -p "$runtime_dir"
    (
        # shellcheck source=/dev/null
        source "$customer_file"
        cat >"$env_file" <<EOF
CUSTOMER_ID=$customer_id
IMAGE_NAME=$ROUTERD_IMAGE_NAME
ROUTERD_SOURCE_ROOT=$source_root
WAN_NETWORK=wan-$customer_id
CM_NETWORK=cm-$customer_id
LAN1_NETWORK=lan-p1-$customer_id
LAN2_NETWORK=lan-p2-$customer_id
LAN3_NETWORK=lan-p3-$customer_id
LAN4_NETWORK=lan-p4-$customer_id
LAN1_MAC=$LAN1_MAC
LAN2_MAC=$LAN2_MAC
LAN3_MAC=$LAN3_MAC
LAN4_MAC=$LAN4_MAC
WAN0_MAC=$WAN0_MAC
EROUTER0_MAC=$EROUTER0_MAC
BRLAN0_IPV4=$BRLAN0_IPV4
BRLAN0_IPV6=$BRLAN0_IPV6
WAN0_IPV4=${WAN0_IPV4:-}
WAN0_IPV6=${WAN0_IPV6:-}
EROUTER0_VLAN=${EROUTER0_VLAN:-}
EROUTER0_IPV4=$EROUTER0_IPV4
EROUTER0_IPV4_GATEWAY=$EROUTER0_IPV4_GATEWAY
EROUTER0_IPV6=$EROUTER0_IPV6
EROUTER0_IPV6_GATEWAY=$EROUTER0_IPV6_GATEWAY
EOF
    )

    printf '%s\n' "$env_file"
}

resolve_routerd_source_root() {
    local candidate=${ROUTERD_SOURCE_ROOT:-}
    if [[ -z "$candidate" ]]; then
        candidate=$(cd "$REPO_ROOT/../routerd" 2>/dev/null && pwd || true)
    fi
    [[ -n "$candidate" && -f "$candidate/Cargo.toml" ]] \
        || die "set ROUTERD_SOURCE_ROOT to the routerd checkout (Cargo.toml not found)"
    printf '%s\n' "$candidate"
}

build_image() {
    require_cmd podman
    podman build -t "$ROUTERD_IMAGE_NAME" "$ROUTERD_ROOT"
}

fetch_workspace() {
    local source_root
    require_cmd cargo
    source_root=$(resolve_routerd_source_root)
    log "fetching routerd deps on host in $source_root"
    (cd "$source_root" && cargo fetch)
}

compile_workspace() {
    local source_root
    require_cmd podman
    source_root=$(resolve_routerd_source_root)
    podman image exists "$ROUTERD_IMAGE_NAME" \
        || die "image $ROUTERD_IMAGE_NAME not found; run 'scripts/routerd build' first"
    [[ -d "$ROUTERD_HOST_CARGO_HOME" ]] \
        || die "host cargo home not found: $ROUTERD_HOST_CARGO_HOME"
    [[ -d "$ROUTERD_HOST_CARGO_HOME/registry" && -d "$ROUTERD_HOST_CARGO_HOME/git" ]] \
        || die "host cargo registry/git caches missing under $ROUTERD_HOST_CARGO_HOME; run 'scripts/routerd fetch' first"
    log "compiling routerd in $source_root via $ROUTERD_IMAGE_NAME"
    podman run --rm \
        -v "$source_root":/workspace \
        -v "$ROUTERD_HOST_CARGO_HOME/registry":/usr/local/cargo/registry:ro \
        -v "$ROUTERD_HOST_CARGO_HOME/git":/usr/local/cargo/git:ro \
        -w /workspace \
        --entrypoint cargo \
        "$ROUTERD_IMAGE_NAME" \
        build --release --offline --bin routerd --bin routerctl
}

push_image() {
    push_container_image "$ROUTERD_IMAGE_NAME"
}

compose_up() {
    local customer_id=$1
    local env_file
    env_file=$(compose_env_file "$customer_id")
    (cd "$ROUTERD_ROOT" && "$PODMAN_COMPOSE_BIN" -p "$(compose_project_name "$customer_id")" --env-file "$env_file" up -d)
}

compose_down() {
    local customer_id=$1
    local env_file
    env_file=$(compose_env_file "$customer_id")
    (cd "$ROUTERD_ROOT" && "$PODMAN_COMPOSE_BIN" -p "$(compose_project_name "$customer_id")" --env-file "$env_file" down)
}

container_status() {
    local customer_id=$1
    podman ps -a --filter "name=routerd-${customer_id}"
}

container_logs() {
    local customer_id=$1
    podman logs "routerd-${customer_id}"
}

cmd=${1:-}
customer_id=${2:-}

case "$cmd" in
    build)
        build_image
        ;;
    fetch)
        fetch_workspace
        ;;
    compile)
        compile_workspace
        ;;
    push)
        push_image
        ;;
    up)
        require_routerd_customer_id "$customer_id"
        ensure_routerd_runtime_root
        setup_bridges
        ensure_nat_rule
        compose_up "$customer_id"
        setup_bridges
        ensure_nat_rule
        ;;
    down)
        require_routerd_customer_id "$customer_id"
        ensure_routerd_runtime_root
        compose_down "$customer_id"
        ;;
    status)
        require_routerd_customer_id "$customer_id"
        container_status "$customer_id"
        ;;
    logs)
        require_routerd_customer_id "$customer_id"
        container_logs "$customer_id"
        ;;
    *)
        usage
        exit 1
        ;;
esac
