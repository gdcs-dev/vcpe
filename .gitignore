.DS_Store
.env
__pycache__/
*.pyc
services/routerd/.build-src/
# vcpe local state: operation/deployment artifacts, staged runtime-init binaries
.local/

# AI tool working state
.opencode/

# Go build outputs
controlplane/bin/

# Generated compose.env files staged by the orchestrator into services/<type>/
compose.env

# Generated runtime config trees staged by the orchestrator into services/<type>/runtime/
# (new layout uses etc/ and var/ subdirs; old per-customer dirs were tracked separately)
runtime/

# Generic-container compose.yaml staged by the orchestrator for the client service
services/client/compose.yaml

