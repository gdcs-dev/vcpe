#!/bin/bash
set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
INSTALL_ROOT=${VCPE_INSTALL_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}

export VCPE_INSTALL_ROOT="$INSTALL_ROOT"

source "$INSTALL_ROOT/platform/scripts/lib/common.sh"

TEMPLATES_ROOT="$REPO_ROOT/config"

usage() {
    cat <<'EOF'
Usage: scripts/vcpe <init|up|down|status|logs|config|profile> [args]

Commands:
   init                 create user config under ~/.config/vcpe
   up                   start the configured deployment profile
   down                 stop the configured deployment profile
   status               show status for the configured deployment profile
   logs <service>       show logs for bng, client, mv1, routerd, webpa, or xb10
   config show          print resolved config and profile values
   config set KEY VALUE update ~/.config/vcpe/config.env
   profile list         list available deployment profiles
   profile show [name]  print a deployment profile
   profile use NAME     select the active deployment profile
   profile create NAME [base] copy a profile from an existing base
   profile set NAME KEY VALUE  update a deployment profile key
EOF
}

config_file_path() {
    printf '%s\n' "$CONFIG_ROOT/config.env"
}

profile_file_path() {
    local profile_name=${1:-default}
    printf '%s\n' "$CONFIG_ROOT/profiles/${profile_name}.env"
}

install_template_if_missing() {
    local source_file=$1
    local target_file=$2

    if [[ ! -f "$target_file" ]]; then
        cp "$source_file" "$target_file"
    fi
}

merge_env_file_missing_keys() {
    local source_file=$1
    local target_file=$2
    local raw_line
    local key
    local value

    [[ -f "$source_file" && -f "$target_file" ]] || return 0

    while IFS= read -r raw_line || [[ -n "$raw_line" ]]; do
        [[ -n "$raw_line" && "$raw_line" != \#* && "$raw_line" == *=* ]] || continue
        key=${raw_line%%=*}
        value=${raw_line#*=}
        if ! grep -q "^${key}=" "$target_file"; then
            update_env_file_key "$target_file" "$key" "$value"
        fi
    done < "$source_file"
}

update_env_file_key() {
    local env_file=$1
    local key=$2
    local value=$3
    local temp_file
    local last_char

    temp_file=$(mktemp)

    if grep -q "^${key}=" "$env_file"; then
        awk -F= -v key="$key" -v value="$value" 'BEGIN { updated = 0 } $1 == key { print key "=" value; updated = 1; next } { print } END { if (!updated) print key "=" value }' "$env_file" >"$temp_file"
    else
        cat "$env_file" >"$temp_file"
        if [[ -s "$env_file" ]]; then
            last_char=$(tail -c 1 "$env_file" || true)
            if [[ -n "$last_char" ]]; then
                printf '\n' >>"$temp_file"
            fi
        fi
        printf '%s=%s\n' "$key" "$value" >>"$temp_file"
    fi

    mv "$temp_file" "$env_file"
}

ensure_user_config() {
    local template_file
    local profile_name
    local target_file

    ensure_config_dirs
    target_file=$(config_file_path)
    install_template_if_missing "$TEMPLATES_ROOT/defaults.env" "$target_file"
    merge_env_file_missing_keys "$TEMPLATES_ROOT/defaults.env" "$target_file"

    for template_file in "$TEMPLATES_ROOT"/profiles/*.env; do
        profile_name=$(basename "$template_file")
        target_file="$CONFIG_ROOT/profiles/$profile_name"
        install_template_if_missing "$template_file" "$target_file"
        merge_env_file_missing_keys "$template_file" "$target_file"
    done
}

load_profile_config() {
    local config_file
    local profile_name
    local profile_file

    ensure_user_config

    config_file=$(config_file_path)
    source_env_file "$config_file"

    profile_name=${VCPE_PROFILE:-default}
    profile_file=$(profile_file_path "$profile_name")
    [[ -f "$profile_file" ]] || die "missing deployment profile: $profile_file"
    source_env_file "$profile_file"
}

validate_enabled_profile() {
    if [[ ${DEPLOY_BNG:-0} == 1 ]]; then
        [[ -n "${DEPLOY_BNG_CUSTOMER_ID:-}" ]] || die "DEPLOY_BNG_CUSTOMER_ID is required when DEPLOY_BNG=1"
    fi

    if [[ ${DEPLOY_CLIENT:-0} == 1 ]]; then
        [[ -n "${DEPLOY_CLIENT_TARGET:-}" ]] || die "DEPLOY_CLIENT_TARGET is required when DEPLOY_CLIENT=1"
    fi

    if [[ ${DEPLOY_MV1:-0} == 1 ]]; then
        [[ -n "${DEPLOY_MV1_CUSTOMER_ID:-}" ]] || die "DEPLOY_MV1_CUSTOMER_ID is required when DEPLOY_MV1=1"
    fi

    if [[ ${DEPLOY_XB10:-0} == 1 ]]; then
        [[ -n "${DEPLOY_XB10_CUSTOMER_ID:-}" ]] || die "DEPLOY_XB10_CUSTOMER_ID is required when DEPLOY_XB10=1"
    fi

    if [[ ${DEPLOY_ROUTERD:-0} == 1 ]]; then
        [[ -n "${DEPLOY_ROUTERD_CUSTOMER_ID:-}" ]] || die "DEPLOY_ROUTERD_CUSTOMER_ID is required when DEPLOY_ROUTERD=1"
    fi
}

preflight_runtime() {
    require_cmd podman
    require_cmd "$PODMAN_COMPOSE_BIN"
    podman info >/dev/null
}

service_script() {
    local service_name=$1
    printf '%s\n' "$REPO_ROOT/scripts/${service_name}"
}

run_service() {
    local service_name=$1
    shift
    "$(service_script "$service_name")" "$@"
}

should_pull_image() {
    local pull_policy=${VCPE_PULL_POLICY:-missing}
    local image_name=$1

    case "$pull_policy" in
        always)
            return 0
            ;;
        never)
            return 1
            ;;
        missing)
            if podman image exists "$image_name"; then
                return 1
            fi
            return 0
            ;;
        *)
            die "unsupported pull policy: $pull_policy"
            ;;
    esac
}

pull_image_if_needed() {
    local image_name=$1

    if should_pull_image "$image_name"; then
        log "pulling $image_name"
        podman pull "$image_name"
    fi
}

pull_deployment_images() {
    if [[ ${DEPLOY_BNG:-1} == 1 ]]; then
        pull_image_if_needed "$IMAGE_NAME"
    fi

    if [[ ${DEPLOY_CLIENT:-0} == 1 ]]; then
        pull_image_if_needed "$CLIENT_IMAGE"
    fi

    if [[ ${DEPLOY_WEBPA:-0} == 1 ]]; then
        pull_image_if_needed "$WEBPA_IMAGE_NAME"
    fi

    if [[ ${DEPLOY_MV1:-0} == 1 ]]; then
        pull_image_if_needed "$MV1_IMAGE_NAME"
    fi

    if [[ ${DEPLOY_XB10:-0} == 1 ]]; then
        pull_image_if_needed "$XB10_IMAGE_NAME"
    fi

    if [[ ${DEPLOY_ROUTERD:-0} == 1 ]]; then
        pull_image_if_needed "$ROUTERD_IMAGE_NAME"
    fi
}

deployment_up() {
    load_profile_config
    validate_enabled_profile
    preflight_runtime
    pull_deployment_images

    if [[ ${DEPLOY_BNG:-1} == 1 ]]; then
        run_service bng up "${DEPLOY_BNG_CUSTOMER_ID}"
    fi

    if [[ ${DEPLOY_WEBPA:-0} == 1 ]]; then
        run_service webpa up
    fi

    if [[ ${DEPLOY_MV1:-0} == 1 ]]; then
        run_service mv1 up "${DEPLOY_MV1_CUSTOMER_ID}"
    fi

    if [[ ${DEPLOY_XB10:-0} == 1 ]]; then
        run_service xb10 up "${DEPLOY_XB10_CUSTOMER_ID}"
    fi

    if [[ ${DEPLOY_ROUTERD:-0} == 1 ]]; then
        run_service routerd fetch
        run_service routerd compile
        run_service routerd up "${DEPLOY_ROUTERD_CUSTOMER_ID}"
    fi

    if [[ ${DEPLOY_CLIENT:-0} == 1 ]]; then
        run_service client up "${DEPLOY_CLIENT_TARGET}"
    fi
}

deployment_down() {
    load_profile_config
    validate_enabled_profile
    preflight_runtime

    if [[ ${DEPLOY_XB10:-0} == 1 ]]; then
        run_service xb10 down "${DEPLOY_XB10_CUSTOMER_ID}"
    fi

    if [[ ${DEPLOY_ROUTERD:-0} == 1 ]]; then
        run_service routerd down "${DEPLOY_ROUTERD_CUSTOMER_ID}"
    fi

    if [[ ${DEPLOY_CLIENT:-0} == 1 ]]; then
        run_service client down "${DEPLOY_CLIENT_TARGET}"
    fi

    if [[ ${DEPLOY_MV1:-0} == 1 ]]; then
        run_service mv1 down "${DEPLOY_MV1_CUSTOMER_ID}"
    fi

    if [[ ${DEPLOY_WEBPA:-0} == 1 ]]; then
        run_service webpa down
    fi

    if [[ ${DEPLOY_BNG:-1} == 1 ]]; then
        run_service bng down "${DEPLOY_BNG_CUSTOMER_ID}"
    fi
}

print_status_section() {
    local title=$1
    printf '[%s]\n' "$title"
}

deployment_status() {
    load_profile_config
    validate_enabled_profile
    preflight_runtime

    if [[ ${DEPLOY_BNG:-1} == 1 ]]; then
        print_status_section "bng-${DEPLOY_BNG_CUSTOMER_ID}"
        run_service bng status "${DEPLOY_BNG_CUSTOMER_ID}"
    fi

    if [[ ${DEPLOY_CLIENT:-0} == 1 ]]; then
        print_status_section "client-${DEPLOY_CLIENT_TARGET}"
        run_service client status "${DEPLOY_CLIENT_TARGET}"
    fi

    if [[ ${DEPLOY_WEBPA:-0} == 1 ]]; then
        print_status_section "webpa"
        run_service webpa status
    fi

    if [[ ${DEPLOY_MV1:-0} == 1 ]]; then
        print_status_section "mv1-${DEPLOY_MV1_CUSTOMER_ID}"
        run_service mv1 status "${DEPLOY_MV1_CUSTOMER_ID}"
    fi

    if [[ ${DEPLOY_XB10:-0} == 1 ]]; then
        print_status_section "xb10-${DEPLOY_XB10_CUSTOMER_ID}"
        run_service xb10 status "${DEPLOY_XB10_CUSTOMER_ID}"
    fi

    if [[ ${DEPLOY_ROUTERD:-0} == 1 ]]; then
        print_status_section "routerd-${DEPLOY_ROUTERD_CUSTOMER_ID}"
        run_service routerd status "${DEPLOY_ROUTERD_CUSTOMER_ID}"
    fi
}

deployment_logs() {
    local service_name=${1:-}

    load_profile_config
    validate_enabled_profile
    preflight_runtime

    case "$service_name" in
        bng)
            run_service bng logs "${DEPLOY_BNG_CUSTOMER_ID}"
            ;;
        client)
            run_service client logs "${DEPLOY_CLIENT_TARGET}"
            ;;
        mv1)
            run_service mv1 logs "${DEPLOY_MV1_CUSTOMER_ID}"
            ;;
        routerd)
            run_service routerd logs "${DEPLOY_ROUTERD_CUSTOMER_ID}"
            ;;
        webpa)
            run_service webpa logs
            ;;
        xb10)
            run_service xb10 logs "${DEPLOY_XB10_CUSTOMER_ID}"
            ;;
        *)
            die "usage: scripts/vcpe logs <bng|client|mv1|routerd|webpa|xb10>"
            ;;
    esac
}

config_show() {
    local config_file
    local profile_name
    local profile_file

    load_profile_config
    config_file=$(config_file_path)
    profile_name=${VCPE_PROFILE:-default}
    profile_file=$(profile_file_path "$profile_name")

    cat <<EOF
CONFIG_ROOT=$CONFIG_ROOT
STATE_ROOT=$STATE_ROOT
CONFIG_FILE=$config_file
PROFILE_FILE=$profile_file
VCPE_PROFILE=$profile_name
VCPE_PULL_POLICY=${VCPE_PULL_POLICY:-missing}
PODMAN_COMPOSE_BIN=$PODMAN_COMPOSE_BIN
IMAGE_NAME=$IMAGE_NAME
CLIENT_IMAGE=$CLIENT_IMAGE
MV1_IMAGE_NAME=$MV1_IMAGE_NAME
ROUTERD_IMAGE_NAME=$ROUTERD_IMAGE_NAME
ROUTERD_SOURCE_ROOT=${ROUTERD_SOURCE_ROOT:-}
WEBPA_IMAGE_NAME=$WEBPA_IMAGE_NAME
XB10_IMAGE_NAME=$XB10_IMAGE_NAME
DEPLOY_BNG=${DEPLOY_BNG:-0}
DEPLOY_BNG_CUSTOMER_ID=${DEPLOY_BNG_CUSTOMER_ID:-}
DEPLOY_CLIENT=${DEPLOY_CLIENT:-0}
DEPLOY_CLIENT_TARGET=${DEPLOY_CLIENT_TARGET:-}
DEPLOY_WEBPA=${DEPLOY_WEBPA:-0}
DEPLOY_MV1=${DEPLOY_MV1:-0}
DEPLOY_MV1_CUSTOMER_ID=${DEPLOY_MV1_CUSTOMER_ID:-}
DEPLOY_XB10=${DEPLOY_XB10:-0}
DEPLOY_XB10_CUSTOMER_ID=${DEPLOY_XB10_CUSTOMER_ID:-}
DEPLOY_ROUTERD=${DEPLOY_ROUTERD:-0}
DEPLOY_ROUTERD_CUSTOMER_ID=${DEPLOY_ROUTERD_CUSTOMER_ID:-}
EOF
}

config_set() {
    local key=${1:-}
    local value=${2:-}
    local config_file
    [[ -n "$key" && -n "$value" ]] || die "usage: scripts/vcpe config set KEY VALUE"

    ensure_user_config
    config_file=$(config_file_path)
    update_env_file_key "$config_file" "$key" "$value"
}

list_profiles() {
    ensure_user_config
    find "$CONFIG_ROOT/profiles" -maxdepth 1 -type f -name '*.env' -print | sed 's#.*/##' | sed 's/\.env$//' | sort
}

show_profile() {
    local profile_name=${1:-}
    local profile_file

    ensure_user_config
    if [[ -z "$profile_name" ]]; then
        source_env_file "$(config_file_path)"
        profile_name=${VCPE_PROFILE:-default}
    fi

    profile_file=$(profile_file_path "$profile_name")
    [[ -f "$profile_file" ]] || die "missing deployment profile: $profile_file"
    cat "$profile_file"
}

use_profile() {
    local profile_name=${1:-}
    local profile_file

    [[ -n "$profile_name" ]] || die "usage: scripts/vcpe profile use NAME"
    ensure_user_config
    profile_file=$(profile_file_path "$profile_name")
    [[ -f "$profile_file" ]] || die "missing deployment profile: $profile_file"
    config_set VCPE_PROFILE "$profile_name"
}

create_profile() {
    local profile_name=${1:-}
    local base_profile=${2:-default}
    local source_file
    local target_file

    [[ -n "$profile_name" ]] || die "usage: scripts/vcpe profile create NAME [base]"
    ensure_user_config
    source_file=$(profile_file_path "$base_profile")
    target_file=$(profile_file_path "$profile_name")
    [[ -f "$source_file" ]] || die "missing base profile: $source_file"
    [[ ! -f "$target_file" ]] || die "profile already exists: $profile_name"
    cp "$source_file" "$target_file"
}

set_profile_key() {
    local profile_name=${1:-}
    local key=${2:-}
    local value=${3:-}
    local profile_file

    [[ -n "$profile_name" && -n "$key" && -n "$value" ]] || die "usage: scripts/vcpe profile set NAME KEY VALUE"
    ensure_user_config
    profile_file=$(profile_file_path "$profile_name")
    [[ -f "$profile_file" ]] || die "missing deployment profile: $profile_file"
    update_env_file_key "$profile_file" "$key" "$value"
}

cmd=${1:-}
subcmd=${2:-}

case "$cmd" in
    init)
        ensure_user_config
        config_show
        ;;
    up)
        deployment_up
        ;;
    down)
        deployment_down
        ;;
    status)
        deployment_status
        ;;
    logs)
        deployment_logs "$subcmd"
        ;;
    config)
        case "$subcmd" in
            show)
                config_show
                ;;
            set)
                config_set "${3:-}" "${4:-}"
                ;;
            *)
                die "usage: scripts/vcpe config <show|set>"
                ;;
        esac
        ;;
    profile)
        case "$subcmd" in
            list)
                list_profiles
                ;;
            show)
                show_profile "${3:-}"
                ;;
            use)
                use_profile "${3:-}"
                ;;
            create)
                create_profile "${3:-}" "${4:-default}"
                ;;
            set)
                set_profile_key "${3:-}" "${4:-}" "${5:-}"
                ;;
            *)
                die "usage: scripts/vcpe profile <list|show|use|create|set>"
                ;;
        esac
        ;;
    *)
        usage
        exit 1
        ;;
esac