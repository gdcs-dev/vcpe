#!/bin/bash
set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
INSTALL_ROOT=${VCPE_INSTALL_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}

export VCPE_INSTALL_ROOT="$INSTALL_ROOT"

source "$INSTALL_ROOT/platform/scripts/lib/common.sh"

TAP_NAME_DEFAULT=${VCPE_HOMEBREW_TAP:-gdcs-dev/vcpe}
FORMULA_NAME=vcpe
REPO_URL_DEFAULT=${VCPE_HOMEBREW_REPO_URL:-https://github.com/gdcs-dev/vcpe}
CHANNEL_DEFAULT=${VCPE_HOMEBREW_CHANNEL:-main}

usage() {
    cat <<'EOF'
Usage: scripts/homebrew-tap <init|sync|path|formula> [tap-name]

Commands:
  init [tap-name]     create the Homebrew tap layout
  sync [tap-name]     render the formula into the tap
  path [tap-name]     print the resolved tap path
  formula             print the rendered formula to stdout

Environment:
  VCPE_HOMEBREW_TAP_DIR      override the tap directory for testing
  VCPE_HOMEBREW_CHANNEL      main, development, or release (default: main)
  VCPE_HOMEBREW_MAIN_SHA256  override checksum for the main branch archive (computed from live tarball if unset)
  VCPE_HOMEBREW_DEV_SHA256   override checksum for the development branch archive (computed from live tarball if unset)
  VCPE_HOMEBREW_VERSION      required for release channel
  VCPE_HOMEBREW_SHA256       required for release channel
  VCPE_HOMEBREW_URL          optional source URL override
EOF
}

tap_name() {
  printf '%s\n' "$(normalize_tap_name "${1:-$TAP_NAME_DEFAULT}")"
}

normalize_tap_name() {
  local requested_tap=$1
  local tap_owner=${requested_tap%%/*}
  local tap_repo=${requested_tap#*/}

  [[ -n "$tap_owner" && -n "$tap_repo" && "$requested_tap" == */* ]] || die "tap name must be in owner/repo form"

  if [[ "$tap_repo" != homebrew-* ]]; then
    tap_repo="homebrew-$tap_repo"
  fi

  printf '%s/%s\n' "$tap_owner" "$tap_repo"
}

tap_path() {
    local requested_tap
    local brew_repo
    local tap_owner
    local tap_repo

    if [[ -n "${VCPE_HOMEBREW_TAP_DIR:-}" ]]; then
      printf '%s\n' "$VCPE_HOMEBREW_TAP_DIR"
        return 0
    fi

    requested_tap=$(tap_name "$1")
    tap_owner=${requested_tap%%/*}
    tap_repo=${requested_tap#*/}
    [[ -n "$tap_owner" && -n "$tap_repo" && "$requested_tap" == */* ]] || die "tap name must be in owner/repo form"
    brew_repo=$(brew --repository)
    printf '%s/Library/Taps/%s/%s\n' "$brew_repo" "$tap_owner" "$tap_repo"
}

formula_path() {
    printf '%s/Formula/%s.rb\n' "$(tap_path "$1")" "$FORMULA_NAME"
}

render_formula() {
    local channel=${VCPE_HOMEBREW_CHANNEL:-$CHANNEL_DEFAULT}
    local repo_url=${VCPE_HOMEBREW_REPO_URL:-$REPO_URL_DEFAULT}
    local version_value
    local url_value
    local sha_value
    local head_branch

    case "$channel" in
        main)
            version_value='"main"'
            head_branch="main"
            url_value=${VCPE_HOMEBREW_URL:-${repo_url}/archive/refs/heads/main.tar.gz}
            if [[ -n "${VCPE_HOMEBREW_MAIN_SHA256:-}" ]]; then
                sha_value="$VCPE_HOMEBREW_MAIN_SHA256"
            else
                local tmp_archive
                tmp_archive=$(mktemp /tmp/vcpe-sha-XXXXXX.tar.gz)
                curl -fsSL "$url_value" -o "$tmp_archive" || die "failed to download $url_value"
                sha_value=$(shasum -a 256 "$tmp_archive" | awk '{print $1}')
                rm -f "$tmp_archive"
            fi
            ;;
        development)
            version_value='"development"'
            head_branch="development"
            url_value=${VCPE_HOMEBREW_URL:-${repo_url}/archive/refs/heads/development.tar.gz}
            if [[ -n "${VCPE_HOMEBREW_DEV_SHA256:-}" ]]; then
                sha_value="$VCPE_HOMEBREW_DEV_SHA256"
            else
                local tmp_archive
                tmp_archive=$(mktemp /tmp/vcpe-sha-XXXXXX.tar.gz)
                curl -fsSL "$url_value" -o "$tmp_archive" || die "failed to download $url_value"
                sha_value=$(shasum -a 256 "$tmp_archive" | awk '{print $1}')
                rm -f "$tmp_archive"
            fi
            ;;
        release)
            # Auto-detect version from latest git tag if not explicitly set.
            version_value=${VCPE_HOMEBREW_VERSION:-}
            if [[ -z "$version_value" ]]; then
                local latest_tag
                latest_tag=$(git -C "$REPO_ROOT" describe --tags --abbrev=0 2>/dev/null || true)
                [[ -n "$latest_tag" ]] || die "no git tags found; create a tag or set VCPE_HOMEBREW_VERSION"
                version_value=${latest_tag#v}
            fi
            head_branch="main"
            url_value=${VCPE_HOMEBREW_URL:-${repo_url}/archive/refs/tags/v${version_value}.tar.gz}
            # Auto-compute sha256 if not set (same pattern as main/development).
            if [[ -n "${VCPE_HOMEBREW_SHA256:-}" ]]; then
                sha_value="$VCPE_HOMEBREW_SHA256"
            else
                local tmp_archive
                tmp_archive=$(mktemp /tmp/vcpe-sha-XXXXXX.tar.gz)
                curl -fsSL "$url_value" -o "$tmp_archive" || die "failed to download $url_value (is the tag pushed to GitHub?)"
                sha_value=$(shasum -a 256 "$tmp_archive" | awk '{print $1}')
                rm -f "$tmp_archive"
            fi
            version_value=$(printf '"%s"' "$version_value")
            ;;
        *)
            die "unsupported Homebrew channel: $channel"
            ;;
    esac

    cat <<EOF
class Vcpe < Formula
  desc "Podman-based vCPE lab orchestration"
  homepage "$repo_url"
  url "$url_value"
  version $version_value
  sha256 "$sha_value"
  license "MIT"
  head "$repo_url.git", branch: "$head_branch"

  depends_on "go" => :build
  depends_on "podman"
  depends_on "podman-compose"

  def install
    cd "controlplane" do
      system "go", "build",
             "-ldflags", "-s -w -X 'main.version=#{version}'",
             "-o", bin/"vcpe",
             "./cmd/vcpe"
    end
    pkgshare.install "manifests"
    pkgshare.install "services"
  end

  def caveats
    <<~EOS
      Run \`podman machine init\` and \`podman machine start\` on macOS before using vcpe.

      Deployment manifests are installed to:
        #{pkgshare}/manifests/

      To see available manifests:
        vcpe manifest list

      Apply a deployment:
        vcpe apply --manifest <name>    # by name
        vcpe apply                      # auto-select when only one manifest exists

      This formula tracks the $channel branch. The sha256 is a point-in-time
      snapshot; run scripts/sync-homebrew-vcpe after significant pushes to update it.
      Use \`brew install --HEAD vcpe\` to always install the latest $head_branch branch.
    EOS
  end

  test do
    assert_match "vcpe", shell_output("#{bin}/vcpe --help")
  end
end
EOF
}

ensure_tap_layout() {
    local target_tap_path
    local requested_tap

    target_tap_path=$(tap_path "$1")
    requested_tap=$(tap_name "$1")

    if [[ -n "${VCPE_HOMEBREW_TAP_DIR:-}" ]]; then
        mkdir -p "$target_tap_path/Formula"
        return 0
    fi

    if [[ -d "$target_tap_path/Formula" ]]; then
        return 0
    fi

    require_cmd brew
    brew tap-new --no-git --branch main "$requested_tap"
}

sync_tap() {
    local target_formula_path

    ensure_tap_layout "$1"
    target_formula_path=$(formula_path "$1")
    mkdir -p "$(dirname "$target_formula_path")"
    render_formula >"$target_formula_path"
}

cmd=${1:-}
requested_tap=${2:-}

case "$cmd" in
    init)
        ensure_tap_layout "$requested_tap"
        ;;
    sync)
        sync_tap "$requested_tap"
        ;;
    path)
        tap_path "$requested_tap"
        ;;
    formula)
        render_formula
        ;;
    *)
        usage
        exit 1
        ;;
esac